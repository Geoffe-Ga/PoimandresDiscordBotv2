# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Bot token from the Discord Developer Portal (Bot > Token).
DISCORD_TOKEN=your-bot-token-here

# Application / client ID (Discord Developer Portal > General Information).
DISCORD_CLIENT_ID=your-application-id-here

# Guild ID used for instant slash-command sync during development.
DISCORD_DEV_GUILD_ID=your-development-guild-id-here
